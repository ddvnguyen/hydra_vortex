{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["CLAUDE.md", "docs/workflow/*.md"],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
    },
    "plane": {
      "type": "local",
      "command": ["/home/ddv/.local/bin/uvx", "plane-mcp-server", "stdio"],
      "enabled": true,
      "environment": {
        "PLANE_API_KEY": "${PLANE_API_KEY}",
        "PLANE_WORKSPACE_SLUG": "hydra-vortex",
        "PLANE_BASE_URL": "https://api.plane.so"
      }
    }
  }
}
