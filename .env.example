# =============================================================================
# Hydra — Environment Configuration
# Copy this to .env and adjust for your setup
# =============================================================================

# ── Coordinator ──────────────────────────────────────────────────────────────
HYDRA_COORD_HOST=0.0.0.0
HYDRA_COORD_PORT=9000
HYDRA_COORD_LOG_LEVEL=INFO
HYDRA_COORD_STORE_HOST=127.0.0.1
HYDRA_COORD_STORE_PORT=9500
# HYDRA_LLAMA_ENGINE=true        # Use RPC-based engine (llama-engine) instead of HTTP proxy

# M-Perf.9 #289: cross-model KV safety. When set to true, the Coordinator allows
# a RestoreKvAsync whose stored model_hash differs from the slot's model_hash
# (logs a warning + emits hydra_cross_model_kv_warned_total, but proceeds). Default
# false: a hash mismatch aborts the restore, erases the slot, and re-prefills on
# the correct model. Set to true ONLY if you have a deliberate reason to mix
# models across P/D phases and accept the corrupt-decode risk.
# HYDRA_COORD_ALLOW_CROSS_MODEL_KV_REUSE=false

# ── Nodes (Coordinator sees these) ───────────────────────────────────────────
# RTX node
HYDRA_COORD_NODES__0__NAME=rtx
HYDRA_COORD_NODES__0__HOST=127.0.0.1
HYDRA_COORD_NODES__0__RPC_PORT=9601
HYDRA_COORD_NODES__0__LLAMA_URL=http://localhost:8080
HYDRA_COORD_NODES__0__GPU_TYPE=rtx5060ti

# P100 node (KVM VM)
HYDRA_COORD_NODES__1__NAME=p100
HYDRA_COORD_NODES__1__HOST=192.168.122.21
HYDRA_COORD_NODES__1__RPC_PORT=9602
HYDRA_COORD_NODES__1__LLAMA_URL=http://192.168.122.21:8081
HYDRA_COORD_NODES__1__GPU_TYPE=p100

# ── Hydra.Store ──────────────────────────────────────────────────────────────
# Store defaults to 0.0.0.0:9500, path /mnt/llm-ram/store, debug :9501
# These are compiled into StoreConfig.cs — no env override currently.

# ── Hydra.Agent ──────────────────────────────────────────────────────────────
# Agent defaults to 0.0.0.0:9601, node_name=rtx, llama=http://localhost:8080
# These are compiled into AgentConfig.cs — no env override currently.
# Use launch.json env blocks or modify Program.cs for different instances.

# ── llama-server ─────────────────────────────────────────────────────────────
# LLAMA_ARG_RPC_PORT=9601        # RPC port for state streaming
# LLAMA_ARG_PORT=8080             # HTTP port
# LLAMA_ARG_N_GPU=99
# LLAMA_ARG_CTX_SIZE=81920
# LLAMA_ARG_SLOT_SAVE_PATH=/tmp/hydra-kv
