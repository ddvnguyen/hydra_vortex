{
  "title": "Hydra Dashboard",
  "version": 4,
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "type": "row",
      "title": "Service Metrics",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Request Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_requests_total[1m])",
          "legendFormat": "{{node}}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Active Sessions",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(hydra_active_sessions)",
          "legendFormat": "sessions"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Store Ops/s",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_store_ops_total[1m])",
          "legendFormat": "{{op}}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Store Bytes/s",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_store_bytes_stored[1m]) + rate(hydra_store_bytes_sent[1m])",
          "legendFormat": "bytes/s"
        }
      ],
      "unit": "bytes",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Cache Hit Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_cache_hits_total[1m]) / (rate(hydra_requests_total[1m]) + 0.001) * 100",
          "legendFormat": "hit %"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Migration Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_migrations_total[1m])",
          "legendFormat": "{{from}}\u2192{{to}}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "row",
      "title": "Agent Performance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      }
    },
    {
      "type": "timeseries",
      "title": "Save Duration (p50/p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hydra_agent_save_duration_seconds_bucket{job=~\"hydra-agent.*\"}[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hydra_agent_save_duration_seconds_bucket{job=~\"hydra-agent.*\"}[1m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Restore Duration (p50/p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hydra_agent_restore_duration_seconds_bucket{job=~\"hydra-agent.*\"}[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hydra_agent_restore_duration_seconds_bucket{job=~\"hydra-agent.*\"}[1m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Host & GPU",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      }
    },
    {
      "type": "gauge",
      "title": "GPU Utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "max by(gpu, modelName, node) (DCGM_FI_DEV_GPU_UTIL{job=~\"hydra-gpu.*\"})\nor max by(modelName, node) (label_replace(nvidia_smi_utilization_gpu_ratio{job=~\"hydra-gpu.*\"} * 100, \"modelName\", \"$1\", \"name\", \"(.+)\"))",
          "legendFormat": "{{modelName}} ({{node}})"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 17
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "thresholds": [
          {
            "color": "green",
            "value": null
          },
          {
            "color": "orange",
            "value": 70
          },
          {
            "color": "red",
            "value": 90
          }
        ]
      }
    },
    {
      "type": "gauge",
      "title": "GPU Memory",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(max by(gpu, modelName, node) (DCGM_FI_DEV_FB_USED{job=~\"hydra-gpu.*\"}) / (max by(gpu, modelName, node) (DCGM_FI_DEV_FB_USED{job=~\"hydra-gpu.*\"}) + max by(gpu, modelName, node) (DCGM_FI_DEV_FB_FREE{job=~\"hydra-gpu.*\"})) * 100)\nor max by(modelName, node) (label_replace(nvidia_smi_memory_used_bytes{job=~\"hydra-gpu.*\"} / nvidia_smi_memory_total_bytes{job=~\"hydra-gpu.*\"} * 100, \"modelName\", \"$1\", \"name\", \"(.+)\"))",
          "legendFormat": "{{modelName}} ({{node}})"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 17
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "thresholds": [
          {
            "color": "green",
            "value": null
          },
          {
            "color": "orange",
            "value": 80
          },
          {
            "color": "red",
            "value": 95
          }
        ]
      }
    },
    {
      "type": "stat",
      "title": "GPU Temperature",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "max by(gpu, modelName, node) (DCGM_FI_DEV_GPU_TEMP{job=~\"hydra-gpu.*\"})\nor max by(modelName, node) (label_replace(nvidia_smi_temperature_gpu{job=~\"hydra-gpu.*\"}, \"modelName\", \"$1\", \"name\", \"(.+)\"))",
          "legendFormat": "{{modelName}} ({{node}})"
        }
      ],
      "unit": "celsius",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 17
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "GPU Power",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "max by(gpu, modelName, node) (DCGM_FI_DEV_POWER_USAGE{job=~\"hydra-gpu.*\"})\nor max by(modelName, node) (label_replace(nvidia_smi_power_draw_watts{job=~\"hydra-gpu.*\"}, \"modelName\", \"$1\", \"name\", \"(.+)\"))",
          "legendFormat": "{{modelName}} ({{node}})"
        }
      ],
      "unit": "watt",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 12,
        "y": 17
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "CPU Utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "cpu"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 17
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Memory Utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "memory"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 17
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "row",
      "title": "llama-server Inference",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      }
    },
    {
      "type": "timeseries",
      "title": "Tokens per Second",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(llamacpp_tokens_predicted_total[1m])",
          "legendFormat": "decode {{node}}"
        },
        {
          "expr": "rate(llamacpp_prompt_tokens_total[1m])",
          "legendFormat": "prompt {{node}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Requests Processing",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "llamacpp_requests_processing",
          "legendFormat": "{{node}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 24
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "KV Cache Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "llamacpp_kv_cache_usage_ratio * 100",
          "legendFormat": "{{node}}"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 24
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Service Health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
    {
      "type": "table",
      "title": "Target Status",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{component}} {{node}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Value",
            "desc": false
          }
        ]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text",
                  "mode": "basic"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "stat",
      "title": "llama-server Health (RTX)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "up{component=\"llama-server\",node=\"rtx\"}",
          "legendFormat": "rtx"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "llama-server Health (P100)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "up{component=\"llama-server\",node=\"p100\"}",
          "legendFormat": "p100"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Agent Slots (RTX)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_agent_slots_idle{node=\"rtx\"}",
          "legendFormat": "idle rtx"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 18,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Agent Slots (P100)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_agent_slots_idle{node=\"p100\"}",
          "legendFormat": "idle p100"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 21,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Request Timeline (Last 20)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 35
      }
    },
    {
      "id": 100,
      "type": "table",
      "title": "Per-Request Phase Durations",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "expr": "{service=\"hydra-coordinator\"} |= \"request_timeline\"",
          "maxLines": 20,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "line",
            "format": "logfmt"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": false,
              "trace_id": false,
              "session_id": false,
              "route_type": false,
              "node": false,
              "queue_wait_ms": false,
              "n_past_guard_ms": false,
              "prefill_ms": false,
              "save_kv_ms": false,
              "restore_kv_ms": false,
              "decode_ms": false,
              "total_ms": false,
              "Line": true,
              "labels": true,
              "ts": true,
              "msg": true,
              "level": true,
              "logger": true,
              "caller": true
            },
            "indexByName": {
              "Time": 0,
              "trace_id": 1,
              "session_id": 2,
              "route_type": 3,
              "node": 4,
              "queue_wait_ms": 5,
              "n_past_guard_ms": 6,
              "prefill_ms": 7,
              "save_kv_ms": 8,
              "restore_kv_ms": 9,
              "decode_ms": 10,
              "total_ms": 11
            },
            "renameByName": {
              "total_ms": "total (ms)",
              "queue_wait_ms": "queue (ms)",
              "n_past_guard_ms": "guard (ms)",
              "prefill_ms": "prefill (ms)",
              "save_kv_ms": "save (ms)",
              "restore_kv_ms": "restore (ms)",
              "decode_ms": "decode (ms)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "minWidth": 80
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "queue (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 30000
              },
              {
                "id": "custom.minWidth",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "guard (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 5000
              },
              {
                "id": "custom.minWidth",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "prefill (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 120000
              },
              {
                "id": "custom.minWidth",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "save (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 30000
