{
  "title": "Hydra Dashboard",
  "version": 5,
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "type": "row",
      "title": "Service Metrics",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Request Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_requests_total[1m])",
          "legendFormat": "{{node}}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Active Sessions",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(hydra_active_sessions)",
          "legendFormat": "sessions"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Store Ops/s",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_store_ops_total[1m])",
          "legendFormat": "{{op}}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Store Bytes/s",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_store_bytes_stored[1m]) + rate(hydra_store_bytes_sent[1m])",
          "legendFormat": "bytes/s"
        }
      ],
      "unit": "bytes",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Cache Hit Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_cache_hits_total[1m]) / (rate(hydra_requests_total[1m]) + 0.001) * 100",
          "legendFormat": "hit %"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Migration Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_migrations_total[1m])",
          "legendFormat": "{{from}}\u2192{{to}}"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "row",
      "title": "Agent Performance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      }
    },
    {
      "type": "timeseries",
      "title": "Save Duration (p50/p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hydra_agent_save_duration_seconds_bucket{job=~\"hydra-agent.*\"}[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hydra_agent_save_duration_seconds_bucket{job=~\"hydra-agent.*\"}[1m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Restore Duration (p50/p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hydra_agent_restore_duration_seconds_bucket{job=~\"hydra-agent.*\"}[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hydra_agent_restore_duration_seconds_bucket{job=~\"hydra-agent.*\"}[1m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Host & GPU",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      }
    },
    {
      "type": "gauge",
      "title": "GPU Utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "max by(gpu, modelName, node) (DCGM_FI_DEV_GPU_UTIL{job=~\"hydra-gpu.*\"})\nor max by(modelName, node) (label_replace(nvidia_smi_utilization_gpu_ratio{job=~\"hydra-gpu.*\"} * 100, \"modelName\", \"$1\", \"name\", \"(.+)\"))",
          "legendFormat": "{{modelName}} ({{node}})"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 17
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "thresholds": [
          {
            "color": "green",
            "value": null
          },
          {
            "color": "orange",
            "value": 70
          },
          {
            "color": "red",
            "value": 90
          }
        ]
      }
    },
    {
      "type": "gauge",
      "title": "GPU Memory",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(max by(gpu, modelName, node) (DCGM_FI_DEV_FB_USED{job=~\"hydra-gpu.*\"}) / (max by(gpu, modelName, node) (DCGM_FI_DEV_FB_USED{job=~\"hydra-gpu.*\"}) + max by(gpu, modelName, node) (DCGM_FI_DEV_FB_FREE{job=~\"hydra-gpu.*\"})) * 100)\nor max by(modelName, node) (label_replace(nvidia_smi_memory_used_bytes{job=~\"hydra-gpu.*\"} / nvidia_smi_memory_total_bytes{job=~\"hydra-gpu.*\"} * 100, \"modelName\", \"$1\", \"name\", \"(.+)\"))",
          "legendFormat": "{{modelName}} ({{node}})"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 17
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "thresholds": [
          {
            "color": "green",
            "value": null
          },
          {
            "color": "orange",
            "value": 80
          },
          {
            "color": "red",
            "value": 95
          }
        ]
      }
    },
    {
      "type": "stat",
      "title": "GPU Temperature",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "max by(gpu, modelName, node) (DCGM_FI_DEV_GPU_TEMP{job=~\"hydra-gpu.*\"})\nor max by(modelName, node) (label_replace(nvidia_smi_temperature_gpu{job=~\"hydra-gpu.*\"}, \"modelName\", \"$1\", \"name\", \"(.+)\"))",
          "legendFormat": "{{modelName}} ({{node}})"
        }
      ],
      "unit": "celsius",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 17
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "GPU Power",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "max by(gpu, modelName, node) (DCGM_FI_DEV_POWER_USAGE{job=~\"hydra-gpu.*\"})\nor max by(modelName, node) (label_replace(nvidia_smi_power_draw_watts{job=~\"hydra-gpu.*\"}, \"modelName\", \"$1\", \"name\", \"(.+)\"))",
          "legendFormat": "{{modelName}} ({{node}})"
        }
      ],
      "unit": "watt",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 12,
        "y": 17
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "CPU Utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "cpu"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 17
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "Memory Utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "memory"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 17
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "row",
      "title": "llama-server Inference",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      }
    },
    {
      "type": "timeseries",
      "title": "Tokens per Second",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(llamacpp_tokens_predicted_total[1m])",
          "legendFormat": "decode {{node}}"
        },
        {
          "expr": "rate(llamacpp_prompt_tokens_total[1m])",
          "legendFormat": "prompt {{node}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Requests Processing",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "llamacpp_requests_processing",
          "legendFormat": "{{node}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 24
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "KV Cache Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "llamacpp_kv_cache_usage_ratio * 100",
          "legendFormat": "{{node}}"
        }
      ],
      "unit": "percent",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 24
      },
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Service Health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
    {
      "type": "table",
      "title": "Target Status",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{component}} {{node}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Value",
            "desc": false
          }
        ]
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text",
                  "mode": "basic"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "stat",
      "title": "llama-server Health (RTX)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "up{component=\"llama-server\",node=\"rtx\"}",
          "legendFormat": "rtx"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "llama-server Health (P100)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "up{component=\"llama-server\",node=\"p100\"}",
          "legendFormat": "p100"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Agent Slots (RTX)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_agent_slots_idle{node=\"rtx\"}",
          "legendFormat": "idle rtx"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 18,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Agent Slots (P100)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_agent_slots_idle{node=\"p100\"}",
          "legendFormat": "idle p100"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 21,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "P/D Performance (Issue #306 bench)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      }
    },
    {
      "type": "timeseries",
      "title": "P/D request rate (req/s, by node × phase)",
      "description": "Issue #306: aggregate prefill + decode request rates over time. Backed by hydra_prefill_seconds and hydra_decode_seconds histograms. Read by s4_cold_concurrency and s3_cold_atomic.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (node) (rate(hydra_prefill_seconds_count[1m]))",
          "legendFormat": "prefill {{node}}"
        },
        {
          "expr": "sum by (node) (rate(hydra_decode_seconds_count[1m]))",
          "legendFormat": "decode {{node}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Warm-slot hit rate",
      "description": "Issue #306: share of requests served from a warm slot vs cold prefill. The S1 success criterion is >=0.95 P50 over a multi-turn session. A persistent drop to 0 with non-zero hydra_stuck_warm_leases_total is the S10 canary.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(hydra_warm_session_starts[5m])) / clamp_min(sum(rate(hydra_warm_session_starts[5m])) + sum(rate(hydra_cold_session_starts[5m])), 0.001)",
          "legendFormat": "warm hit rate"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Phase latency p99 (s)",
      "description": "Issue #306: per-phase p99 latency for prefill + decode. Use this to spot regressions early — the compare.py regression gate fires when p95 regresses >10% on S4.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, session_type) (rate(hydra_prefill_seconds_bucket[5m])))",
          "legendFormat": "prefill p99 {{session_type}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, session_type) (rate(hydra_decode_seconds_bucket[5m])))",
          "legendFormat": "decode p99 {{session_type}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Queue depth (active requests at each stage)",
      "description": "Issue #306 + E4 (#269): the number of requests currently sitting in each pipeline stage. A persistently positive decode queue with an empty prefill queue means the prefill stage is the bottleneck; the reverse means the decode stage is.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_main_queue_depth",
          "legendFormat": "main (classifier)"
        },
        {
          "expr": "hydra_prefill_queue_depth",
          "legendFormat": "prefill"
        },
        {
          "expr": "hydra_decode_queue_depth",
          "legendFormat": "decode"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    }
  ]
}