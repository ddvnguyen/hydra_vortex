{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "Coordinator system: scheduler decisions, worker health, prefix checkpoint, edge cases",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Full Dashboard",
      "url": "/d/hydra-dashboard",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Logs",
      "url": "/d/hydra-logs",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "id": 1,
      "title": "Overview",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Request Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_requests_total[1m])",
          "legendFormat": "{{reason}} {{node}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "reduceOptions": {
          "calcs": ["sum"]
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Sessions",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(hydra_active_sessions)",
          "legendFormat": "sessions",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      }
    },
    {
      "type": "stat",
      "title": "RTX Worker Tracker",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_worker_busy_seconds{node=\"rtx\"}",
          "legendFormat": "rtx",
          "refId": "A"
        }
      ],
      "unit": "s",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FREE", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "P100 Worker Tracker",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_worker_busy_seconds{node=\"p100\"}",
          "legendFormat": "p100",
          "refId": "A"
        }
      ],
      "unit": "s",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 300 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FREE", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Cross-Node Affinity",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "increase(hydra_cross_node_affinity_total[1h])",
          "legendFormat": "cross-node",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Upstream Timeouts",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "increase(hydra_upstream_timeouts_total[1h])",
          "legendFormat": "timeouts",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "collapsed": false,
      "id": 2,
      "title": "Scheduler Decisions",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "type": "timeseries",
      "title": "Routing Rate by Path",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(hydra_requests_total[$__rate_interval])",
          "legendFormat": "{{reason}} {{node}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "req/s"
        }
      }
    },
    {
      "type": "piechart",
      "title": "Requests Distribution",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "increase(hydra_requests_total[$__range])",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "pie",
        "reduceOptions": {
          "values": false,
          "calcs": ["sum"]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 },
              { "color": "orange", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Active Sessions per Node",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_active_sessions{node=~\"rtx|p100\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "collapsed": false,
      "id": 3,
      "title": "Worker Health",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      }
    },
    {
      "type": "timeseries",
      "title": "Worker Busy Seconds — Tracker Leak Detection",
      "description": "Monotonically increasing = tracker leak. Flat at 0 = free. Climbing = legitimate request.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_worker_busy_seconds{node=~\"rtx|p100\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Agent Slots Idle",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_agent_slots_idle{node=~\"rtx|p100\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 15
      },
      "options": {
        "legend": {
          "calcs": ["mean", "min"],
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "type": "stat",
      "title": "Current Slots / Trackers",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "hydra_agent_slots_idle{node=\"rtx\"}",
          "legendFormat": "RTX idle slots",
          "refId": "A"
        },
        {
          "expr": "hydra_agent_slots_idle{node=\"p100\"}",
          "legendFormat": "P100 idle slots",
          "refId": "B"
        },
        {
          "expr": "hydra_worker_busy_seconds{node=\"rtx\"}",
          "legendFormat": "RTX busy (s)",
          "refId": "C"
        },
        {
          "expr": "hydra_worker_busy_seconds{node=\"p100\"}",
          "legendFormat": "P100 busy (s)",
          "refId": "D"
        },
        {
          "expr": "sum(hydra_active_sessions)",
          "legendFormat": "Sessions",
          "refId": "E"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 15
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "values": true,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 600 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "RTX idle slots" },
            "properties": [
              { "id": "displayName", "value": "RTX Slots" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P100 idle slots" },
            "properties": [
              { "id": "displayName", "value": "P100 Slots" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RTX busy (s)" },
            "properties": [
              { "id": "displayName", "value": "RTX Tracker" },
              { "id": "unit", "value": "s" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P100 busy (s)" },
            "properties": [
              { "id": "displayName", "value": "P100 Tracker" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      }
    },
    {
      "collapsed": false,
      "id": 4,
      "title": "Prefix Checkpoint",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      }
    },
    {
      "type": "timeseries",
      "title": "Prefix Events (from logs)",
      "description": "Count of prefix_saved and prefix_restored events from coordinator logs.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count_over_time({component=\"hydra\"} |= \"prefix_saved\" [$__interval])",
          "legendFormat": "saves",
          "queryType": "range",
          "refId": "A"
        },
        {
          "expr": "count_over_time({component=\"hydra\"} |= \"prefix_restored\" [$__interval])",
          "legendFormat": "restores",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "type": "stat",
      "title": "Prefix Dedup Efficiency",
      "description": "Restores per save — higher is better. Resets every dashboard range.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"hydra\"} |= \"prefix_restored\" [$__range])) / sum(count_over_time({component=\"hydra\"} |= \"prefix_saved\" [$__range]))",
          "legendFormat": "restores/save",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 24
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Prefix Save vs Restore (absolute)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"hydra\"} |= \"prefix_restored\" [$__range]))",
          "legendFormat": "restores",
          "queryType": "range",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({component=\"hydra\"} |= \"prefix_saved\" [$__range]))",
          "legendFormat": "saves",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 24
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "values": true,
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "collapsed": false,
      "id": 5,
      "title": "Edge Cases & Errors",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
    {
      "type": "stat",
      "title": "Scheduler Process Failures",
      "description": "Count of scheduler_process_failed events — exceptions in the scheduler _run loop.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"hydra\"} |= \"scheduler_process_failed\" [$__range]))",
          "legendFormat": "failures",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "n_past Guard Triggered",
      "description": "Count of n_past_guard_triggered events — cache nuked because n_tokens <= n_past.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"hydra\"} |= \"n_past_guard\" [$__range]))",
          "legendFormat": "guards",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Health Check Timeouts",
      "description": "Coordinator health checks that hit ReadTimeout on llama-server.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({component=\"hydra\"} |= \"ReadTimeout\" [$__range]))",
          "legendFormat": "timeouts",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 33
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "collapsed": false,
      "id": 6,
      "title": "Coordinator Logs",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 37
      }
    },
    {
      "type": "logs",
      "title": "All Coordinator Logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{component=\"hydra\"} |= \"$trace_id\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "hydra",
    "coordinator",
    "scheduler"
  ],
  "templating": {
    "list": [
      {
        "name": "trace_id",
        "type": "textbox",
        "query": "",
        "current": {
          "value": ""
        },
        "label": "Trace ID",
        "description": "Filter coordinator logs by trace_id"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Hydra — Coordinator",
  "uid": "hydra-coordinator",
  "version": 1
}
