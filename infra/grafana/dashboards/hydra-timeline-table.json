{
  "title": "Hydra — Request Timeline (Table)",
  "uid": "hydra-timeline-table",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "tags": ["hydra", "timeline", "performance"],
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Per-Request Phase Durations (last 50)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "{component=\"hydra\"} |= \"request_timeline\"",
          "maxLines": 50,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "logfmt"
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "fields": {
              "queue_wait_ms": "number",
              "n_past_guard_ms": "number",
              "prefill_ms": "number",
              "save_kv_ms": "number",
              "restore_kv_ms": "number",
              "decode_ms": "number",
              "total_ms": "number"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "ts": true,
              "msg": true,
              "level": true,
              "timestamp": true,
              "event": true,
              "logger": true,
              "caller": true,
              "id": true
            },
            "indexByName": {
              "Time": 0,
              "trace_id": 1,
              "session_id": 2,
              "route_type": 3,
              "node": 4,
              "queue_wait_ms": 5,
              "n_past_guard_ms": 6,
              "prefill_ms": 7,
              "save_kv_ms": 8,
              "restore_kv_ms": 9,
              "decode_ms": 10,
              "total_ms": 11
            },
            "renameByName": {
              "total_ms": "total (ms)",
              "queue_wait_ms": "queue (ms)",
              "n_past_guard_ms": "guard (ms)",
              "prefill_ms": "prefill (ms)",
              "save_kv_ms": "save (ms)",
              "restore_kv_ms": "restore (ms)",
              "decode_ms": "decode (ms)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "minWidth": 80
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "queue (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 30000
              },
              {
                "id": "custom.minWidth",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "guard (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 5000
              },
              {
                "id": "custom.minWidth",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "prefill (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 120000
              },
              {
                "id": "custom.minWidth",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "save (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 30000
              },
              {
                "id": "custom.minWidth",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "restore (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 60000
              },
              {
                "id": "custom.minWidth",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "decode (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 300000
              },
              {
                "id": "custom.minWidth",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "gradient-gauge"
              },
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 300000
              },
              {
                "id": "custom.minWidth",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "date-time"
              },
              {
                "id": "custom.minWidth",
                "value": 150
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "trace_id"
            },
            "properties": [
              {
                "id": "custom.minWidth",
                "value": 140
              },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "session_id"
            },
            "properties": [
              {
                "id": "custom.minWidth",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "route_type"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "blue", "value": "cold" },
                    { "color": "orange", "value": "warm" },
                    { "color": "purple", "value": "migrate" },
                    { "color": "red", "value": "prefix" }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "node"
            },
            "properties": [
              {
                "id": "custom.minWidth",
                "value": 70
              }
            ]
          }
        ]
      },
      "options": {
        "footer": {
          "show": false
        },
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Time"
          }
        ]
      }
    }
  ],
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "links": [
    {
      "title": "Bars View",
      "url": "/d/hydra-timeline-bars",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ]
