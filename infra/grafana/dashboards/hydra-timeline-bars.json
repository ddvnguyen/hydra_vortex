  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Raw Data",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "{component=\"store\"} |= \"request_timeline\"",
          "maxLines": 20,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "logfmt"
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "fields": {
              "queue_wait_ms": "number",
              "n_past_guard_ms": "number",
              "prefill_ms": "number",
              "save_kv_ms": "number",
              "restore_kv_ms": "number",
              "decode_ms": "number",
              "total_ms": "number"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "ts": true,
              "msg": true,
              "level": true,
              "event": true,
              "logger": true,
              "caller": true,
              "timestamp": true
            },
            "indexByName": {
              "Time": 0,
              "trace_id": 1,
              "session_id": 2,
              "route_type": 3,
              "node": 4,
              "queue_wait_ms": 5,
              "n_past_guard_ms": 6,
              "prefill_ms": 7,
              "save_kv_ms": 8,
              "restore_kv_ms": 9,
              "decode_ms": 10,
              "total_ms": 11
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "minWidth": 80
          }
        }
      },
      "options": {
        "footer": {
          "show": false
        },
        "frameIndex": 0,
        "showHeader": true
      }
    },
