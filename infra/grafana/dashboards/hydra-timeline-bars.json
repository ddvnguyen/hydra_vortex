{
  "title": "Hydra — Request Timeline",
  "uid": "hydra-timeline-bars",
  "version": 6,
  "timezone": "browser",
  "editable": true,
  "tags": ["hydra", "timeline", "performance"],
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Recent 20 Requests — phase durations + nodes",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "{component=\"hydra\"} |= \"request_timeline\"",
          "maxLines": 20,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "extractFields", "options": { "source": "Line", "format": "kvp" } },
        {
          "id": "convertFieldType",
          "options": {
            "fields": {
              "queue_wait_ms": "number",
              "prefill_ms": "number",
              "save_kv_ms": "number",
              "restore_kv_ms": "number",
              "decode_ms": "number",
              "total_ms": "number"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "ts": true,
              "msg": true,
              "level": true,
              "timestamp": true,
              "event": true,
              "logger": true,
              "caller": true,
              "id": true,
              "node": true,
              "tsNs": true
            },
            "indexByName": {
              "Time": 0,
              "trace_id": 1,
              "session_id": 2,
              "route_type": 3,
              "prefill_node": 4,
              "decode_node": 5,
              "queue_wait_ms": 6,
              "prefill_ms": 7,
              "save_kv_ms": 8,
              "restore_kv_ms": 9,
              "decode_ms": 10,
              "total_ms": 11
            },
            "renameByName": {
              "prefill_node": "prefill node",
              "decode_node": "decode node",
              "queue_wait_ms": "queue",
              "prefill_ms": "prefill",
              "save_kv_ms": "save kv",
              "restore_kv_ms": "restore kv",
              "decode_ms": "decode",
              "total_ms": "total"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Time", "desc": true }] }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "minWidth": 70 },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "queue" },
            "properties": [
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "unit", "value": "dtdurationms" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 30000 },
              { "id": "custom.minWidth", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "prefill" },
            "properties": [
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "unit", "value": "dtdurationms" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 120000 },
              { "id": "custom.minWidth", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "save kv" },
            "properties": [
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "unit", "value": "dtdurationms" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 30000 },
              { "id": "custom.minWidth", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "restore kv" },
            "properties": [
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "unit", "value": "dtdurationms" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 60000 },
              { "id": "custom.minWidth", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "decode" },
            "properties": [
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "unit", "value": "dtdurationms" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 300000 },
              { "id": "custom.minWidth", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "unit", "value": "dtdurationms" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 300000 },
              { "id": "custom.minWidth", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.minWidth", "value": 150 }]
          },
          {
            "matcher": { "id": "byName", "options": "trace_id" },
            "properties": [
              { "id": "custom.minWidth", "value": 140 },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "prefill node" },
            "properties": [{ "id": "custom.minWidth", "value": 90 }]
          },
          {
            "matcher": { "id": "byName", "options": "decode node" },
            "properties": [{ "id": "custom.minWidth", "value": 90 }]
          }
        ]
      },
      "options": {
        "footer": { "show": false },
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }]
      }
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Phase Durations per Request (stacked — one bar per request, newest first)",
      "description": "Each horizontal bar is one request (trace_id). Segments are per-phase durations; segments sum to ≈ total_ms. Prefill/save run on the prefill node, restore/decode on the decode node — see the table above.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "{component=\"hydra\"} |= \"request_timeline\"",
          "maxLines": 20,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "extractFields", "options": { "source": "Line", "format": "kvp" } },
        {
          "id": "convertFieldType",
          "options": {
            "fields": {
              "queue_wait_ms": "number",
              "prefill_ms": "number",
              "save_kv_ms": "number",
              "restore_kv_ms": "number",
              "decode_ms": "number"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Time", "desc": true }] }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Line": true,
              "labels": true,
              "ts": true,
              "msg": true,
              "level": true,
              "timestamp": true,
              "event": true,
              "logger": true,
              "caller": true,
              "id": true,
              "node": true,
              "tsNs": true,
              "session_id": true,
              "route_type": true,
              "prefill_node": true,
              "decode_node": true,
              "total_ms": true
            },
            "indexByName": {
              "trace_id": 0,
              "queue_wait_ms": 1,
              "prefill_ms": 2,
              "save_kv_ms": 3,
              "restore_kv_ms": 4,
              "decode_ms": 5
            },
            "renameByName": {
              "queue_wait_ms": "Queue",
              "prefill_ms": "Prefill",
              "save_kv_ms": "Save KV",
              "restore_kv_ms": "Restore KV",
              "decode_ms": "Decode"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurationms",
          "min": 0,
          "custom": {
            "fillOpacity": 90,
            "lineWidth": 0,
            "gradientMode": "none",
            "axisPlacement": "auto",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Queue" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#7EB26D", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Prefill" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#E24D42", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Save KV" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F2C96D", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Restore KV" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#BF1B72", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Decode" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#1F78C1", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "stacking": "normal",
        "showValue": "never",
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    }
  ],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {}
}
